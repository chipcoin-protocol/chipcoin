# Supported local network profiles:
# - devnet: current public devnet defaults below
# - testnet: dry-run only until public testnet bootstrap/snapshot services exist
#   For testnet dry-runs use:
#   CHIPCOIN_NETWORK=testnet
#   NODE_DATA_PATH=/var/lib/chipcoin/data/node-testnet.sqlite3
#   NODE_SNAPSHOT_MANIFEST_URLS=
#   NODE_SNAPSHOT_FILE=/var/lib/chipcoin/data/node-testnet.snapshot
#   NODE_P2P_BIND_PORT=28444
#   NODE_HTTP_BIND_PORT=28081
#   NODE_DIRECT_PEERS=
#   NODE_BOOTSTRAP_URL=
CHIPCOIN_NETWORK=devnet
COMPOSE_PROJECT_NAME=chipcoin
CHIPCOIN_RUNTIME_DIR=/var/lib/chipcoin

# Public devnet defaults.
# Do not reuse these for testnet dry-runs; leave testnet bootstrap/snapshot values empty
# until explicit testnet services are deployed.
DEFAULT_NODE_ENDPOINT=https://api.chipcoinprotocol.com
DEFAULT_BOOTSTRAP_PEER=chipcoinprotocol.com:18444
DEFAULT_EXPLORER_URL=https://explorer.chipcoinprotocol.com

# Node
# Phase 1 node runtime does not consume a wallet file yet.
# Public devnet P2P uses TCP 18444. Keep this port consistent with your router/firewall
# rules if you want the node to be reachable by other peers.
# NODE_DATA_PATH must point to a writable SQLite file path, not a directory.
NODE_DATA_PATH=/var/lib/chipcoin/data/node-devnet.sqlite3
NODE_BOOTSTRAP_MODE=auto
# Devnet snapshot manifest. For testnet dry-runs, leave this empty and full-sync.
NODE_SNAPSHOT_MANIFEST_URLS=https://chipcoinprotocol.com/downloads/snapshots/devnet/latest.manifest.json
NODE_SNAPSHOT_FILE=/var/lib/chipcoin/data/node-devnet.snapshot
NODE_SNAPSHOT_TRUST_MODE=warn
NODE_SNAPSHOT_TRUSTED_KEYS_FILE=
NODE_SNAPSHOT_SELECTED_URL=
NODE_SNAPSHOT_SELECTED_HEIGHT=
NODE_SNAPSHOT_SELECTED_HASH=
NODE_LOG_LEVEL=INFO
NODE_P2P_BIND_PORT=18444
NODE_HTTP_BIND_PORT=8081
CHIPCOIN_HTTP_ALLOWED_ORIGINS=
PING_INTERVAL_SECONDS=2.0
P2P_READ_TIMEOUT_SECONDS=15.0
P2P_WRITE_TIMEOUT_SECONDS=15.0
P2P_HANDSHAKE_TIMEOUT_SECONDS=5.0
INITIAL_SYNC_CONSERVATIVE_DEFAULTS=true
BOOTSTRAP_PEER_LIMIT=4
BOOTSTRAP_ANNOUNCE_ENABLED=false
BOOTSTRAP_REFRESH_INTERVAL_SECONDS=60
REWARD_NODE_AUTO_NODE_ID=
REWARD_NODE_AUTO_OWNER_WALLET_FILE=
REWARD_NODE_AUTO_ATTEST_WALLET_FILE=
REWARD_NODE_AUTO_DECLARED_HOST=
REWARD_NODE_AUTO_DECLARED_PORT=
REWARD_NODE_AUTO_RENEW_ENABLED=true
REWARD_NODE_AUTO_ATTEST_ENABLED=true
REWARD_NODE_AUTO_POLL_INTERVAL_SECONDS=5.0

# Miner
# For `node + miner` in the same Docker Compose project, keep `http://node:8081`.
# For a remote miner-only host, point this at the authoritative node API, for example
# `https://api.chipcoinprotocol.com`.
MINER_LOG_LEVEL=INFO
MINER_WALLET_FILE=/var/lib/chipcoin/wallets/chipcoin-wallet.json
MINING_MIN_INTERVAL_SECONDS=1.0
MINING_NODE_URLS=http://node:8081
MINING_MINER_ID=
MINING_POLLING_INTERVAL_SECONDS=2.0
MINING_REQUEST_TIMEOUT_SECONDS=10.0
MINING_NONCE_BATCH_SIZE=250000
MINING_TEMPLATE_REFRESH_SKEW_SECONDS=1

# Browser wallet
BROWSER_WALLET_DEFAULT_NODE_ENDPOINT=https://api.chipcoinprotocol.com

# Service-specific node discovery.
# Devnet public startup peer shown below. For testnet dry-runs leave NODE_DIRECT_PEERS
# and NODE_BOOTSTRAP_URL empty unless you are manually connecting to your own testnet peer.
NODE_DIRECT_PEERS=chipcoinprotocol.com:18444
NODE_DIRECT_PEER=
NODE_BOOTSTRAP_URL=
NODE_PUBLIC_HOST=
NODE_PUBLIC_P2P_PORT=

# Legacy shared discovery fallback
DIRECT_PEERS=
DIRECT_PEER=
BOOTSTRAP_URL=
