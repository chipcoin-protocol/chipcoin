{
  "manifest_version": 3,
  "name": "Chipcoin Wallet",
  "short_name": "Chipcoin",
  "version": "0.1.1",
  "description": "Chipcoin devnet and testnet browser wallet",
  "homepage_url": "https://chipcoinprotocol.com/wallet",
  "action": {
    "default_popup": "popup.html",
    "default_title": "Chipcoin Wallet"
  },
  "background": {
    "scripts": ["assets/background.js"],
    "type": "module"
  },
  "options_ui": {
    "page": "settings.html",
    "open_in_tab": true
  },
  "permissions": ["storage", "alarms"],
  "host_permissions": [
    "https://testnet-api.chipcoinprotocol.com/*",
    "https://api.chipcoinprotocol.com/*",
    "http://127.0.0.1/*",
    "http://localhost/*"
  ],
  "browser_specific_settings": {
    "gecko": {
      "id": "wallet@chipcoinprotocol.com",
      "strict_min_version": "142.0",
      "data_collection_permissions": {
        "required": ["none"]
      }
    }
  }
}
